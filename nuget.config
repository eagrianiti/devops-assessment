<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Clears any inherited/machine-level sources (e.g. a corporate internal feed)
         so this repo always restores from the public nuget.org, regardless of what
         a given machine or CI agent has configured globally. -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
